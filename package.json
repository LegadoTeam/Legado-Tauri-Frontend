{
  "name": "legado_tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "scripts": {
    "typecheck": "vue-tsc --noEmit",
    "dev:desktop": "tauri dev",
    "dev:android": "dotenv -e .env -o -- tauri android dev",
    "build": "vite build",
    "build:android:release": "cross-env RUSTC_WRAPPER=sccache dotenv -e .env -o -- tauri android build --apk --target aarch64",
    "build:windows:release": "cross-env RUSTC_WRAPPER=sccache tauri build --target x86_64-pc-windows-msvc",
    "cache:show": "sccache --show-stats",
    "cache:zero": "sccache --zero-stats",
    "cache:stop": "sccache --stop-server"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@vicons/ionicons5": "^0.13.0",
    "naive-ui": "^2.44.1",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-vue": "^5.2.4",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "typescript": "~5.6.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^32.0.0",
    "vite": "^6.4.2",
    "vue-tsc": "^2.2.12"
  }
}
